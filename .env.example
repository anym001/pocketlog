# PocketLog – Beispielkonfiguration. Datei nach `.env` kopieren und anpassen.

# Reverse Proxy / SWAG
PROXY_NETWORK=swag_default
TZ=Europe/Berlin

# Auth: leer lassen in Produktion (Authentik setzt X-Authentik-Username).
# Für lokales Testen ohne Authentik z.B. DEV_FAKE_USER=test
DEV_FAKE_USER=

# Externe Datenbank — PocketLog bringt keine MariaDB mit.
# DB_HOST = Container-Name (gleicher Docker-Network) ODER IP des MariaDB-Hosts.
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=pocketlog
DB_USER=pocketlog
DB_PASSWORD=change-me
