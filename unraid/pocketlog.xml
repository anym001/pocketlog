<?xml version="1.0"?>
<Container version="2">
  <Name>PocketLog</Name>
  <Repository>ghcr.io/anym001/pocketlog:latest</Repository>
  <Registry>https://github.com/anym001/PocketLog</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/anym001/PocketLog/issues</Support>
  <Project>https://github.com/anym001/PocketLog</Project>
  <Overview>Haushaltsbuch als Progressive Web App. FastAPI-Backend + statische PWA in einem Image. Authentifizierung wird per Authentik Forward Auth (z.B. via SWAG) davor erledigt — die App selbst hat keinen Login. Daten werden in einer externen MariaDB gespeichert, die du selbst betreibst.</Overview>
  <Category>Productivity: Tools:</Category>
  <WebUI>http://[IP]:[PORT:8000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/anym001/PocketLog/main/unraid/pocketlog.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/anym001/PocketLog/main/frontend/icons/icon-192.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Haushaltsbuch als PWA für iPhone, iPad und Mac. Speichert Buchungen, Kategorien und Tags in einer eigenen MariaDB. Multi-User über X-Authentik-Username Header (Forward Auth).</Description>

  <!-- WebUI auf 8080 mappen (frei wählbar) -->
  <Config Name="WebUI Port" Target="8000" Default="8080" Mode="tcp" Description="HTTP-Port. Wenn PocketLog hinter SWAG/Authentik läuft, nicht öffentlich exponieren." Type="Port" Display="always" Required="true" Mask="false">8080</Config>

  <!-- Datenbank -->
  <Config Name="DB_HOST" Target="DB_HOST" Default="mariadb" Mode="" Description="Hostname/Container-Name der externen MariaDB." Type="Variable" Display="always" Required="true" Mask="false">mariadb</Config>
  <Config Name="DB_PORT" Target="DB_PORT" Default="3306" Mode="" Description="MariaDB-Port." Type="Variable" Display="advanced" Required="false" Mask="false">3306</Config>
  <Config Name="DB_NAME" Target="DB_NAME" Default="pocketlog" Mode="" Description="Datenbankname. Muss vorab existieren." Type="Variable" Display="always" Required="true" Mask="false">pocketlog</Config>
  <Config Name="DB_USER" Target="DB_USER" Default="pocketlog" Mode="" Description="DB-User mit Rechten auf DB_NAME." Type="Variable" Display="always" Required="true" Mask="false">pocketlog</Config>
  <Config Name="DB_PASSWORD" Target="DB_PASSWORD" Default="" Mode="" Description="Passwort des DB-Users." Type="Variable" Display="always" Required="true" Mask="true"/>

  <Config Name="TZ" Target="TZ" Default="Europe/Berlin" Mode="" Description="Zeitzone." Type="Variable" Display="advanced" Required="false" Mask="false">Europe/Berlin</Config>
</Container>
